# =============================================================================
# PV-typebot-chat (clone landing) — variáveis de ambiente
# Ver descrição completa em apps/sales/.env.example no monorepo typebot-Saas.
# =============================================================================

# [BUILD — Vite] Produção (Easypanel compile) — sem barra no fim
# VITE_API_BASE_URL=https://api.chattypebot.com
# VITE_PAINEL_URL=https://painel.chattypebot.com

# [DESENVOLVIMENTO LOCAL] vite dev
VITE_API_BASE_URL=http://localhost:3333
VITE_PAINEL_URL=http://localhost:5173

# [RUNTIME — Node] serve-production.mjs
# PORT=3000
# HOST=0.0.0.0

# ERR_NAME_NOT_RESOLVED: o host em VITE_API_BASE_URL precisa de DNS público (A/AAAA)
# ou use temporariamente a URL HTTPS que o Easypanel deu à API.
